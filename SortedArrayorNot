4. Check if Array is Sorted

Concept: Adjacent comparison

Input:
arr = [1, 2, 3, 4, 5]

Output:
true

Input:
arr = [1, 3, 2]

Output:
false

solution:


import java.util.Scanner;
import java.util.Arrays;

class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("input the number of elements in the array");
        int n=sc.nextInt();
        int a[]=new int[n];
        for(int i=0;i<n;i++){
            System.out.println("input"+i+"element ");
            a[i]=sc.nextInt();
        }
        System.out.println("the array is"+Arrays.toString(a));
        //checking if the array is sorted or not
        boolean b=true;
        for(int i=1;i<n;i++){
            if(a[i]<a[i-1]){
                b=false;
            }
        }
        System.out.println("the list is sorted or not "+b);
        
        
    }
}
